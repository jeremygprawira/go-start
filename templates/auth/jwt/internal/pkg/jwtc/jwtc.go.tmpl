package jwtc

import (
	"errors"
	"time"

	"[[.ModuleName]]/internal/config"
	"github.com/golang-jwt/jwt/v5"
)

// Configuration holds JWT issuer and token settings.
type Configuration struct {
	Issuer          string
	AccessSecret    string
	AccessDuration  time.Duration
	RefreshSecret   string
	RefreshDuration time.Duration
}

// Claims extends standard JWT claims with custom fields.
type Claims struct {
	UserID string `json:"user_id"`
	Email  string `json:"email"`
	Role   string `json:"role"`
	jwt.RegisteredClaims
}

// DefaultConfig builds a JWT configuration from app config.
func DefaultConfig(cfg *config.Configuration) *Configuration {
	accessDur, _ := time.ParseDuration(cfg.Authorization.Access.Duration)
	refreshDur, _ := time.ParseDuration(cfg.Authorization.Refresh.Duration)
	return &Configuration{
		Issuer:          cfg.Authorization.Issuer,
		AccessSecret:    cfg.Authorization.Access.Secret,
		AccessDuration:  accessDur,
		RefreshSecret:   cfg.Authorization.Refresh.Secret,
		RefreshDuration: refreshDur,
	}
}

// GenerateAccessToken creates a signed access JWT.
func (c *Configuration) GenerateAccessToken(userID, email, role string) (string, error) {
	claims := &Claims{
		UserID: userID,
		Email:  email,
		Role:   role,
		RegisteredClaims: jwt.RegisteredClaims{
			Issuer:    c.Issuer,
			IssuedAt:  jwt.NewNumericDate(time.Now()),
			ExpiresAt: jwt.NewNumericDate(time.Now().Add(c.AccessDuration)),
		},
	}
	token := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)
	return token.SignedString([]byte(c.AccessSecret))
}

// ParseAccessToken validates and parses an access JWT.
func (c *Configuration) ParseAccessToken(tokenStr string) (*Claims, error) {
	token, err := jwt.ParseWithClaims(tokenStr, &Claims{}, func(t *jwt.Token) (interface{}, error) {
		if _, ok := t.Method.(*jwt.SigningMethodHMAC); !ok {
			return nil, errors.New("unexpected signing method")
		}
		return []byte(c.AccessSecret), nil
	})
	if err != nil {
		return nil, err
	}
	claims, ok := token.Claims.(*Claims)
	if !ok || !token.Valid {
		return nil, errors.New("invalid token")
	}
	return claims, nil
}
