package mysql

import (
	"context"

	"[[.ModuleName]]/internal/models"

	"gorm.io/gorm"
)

// MySQLRepository aggregates all MySQL repositories.
type MySQLRepository struct {
	Health HealthRepository
	User   UserRepository
}

func New(db *gorm.DB) *MySQLRepository {
	return &MySQLRepository{
		Health: NewHealthRepository(db),
		User:   NewUserRepository(db),
	}
}

// HealthRepository handles health check queries.
type HealthRepository interface {
	Ping(ctx context.Context) error
}

// UserRepository handles user data access.
type UserRepository interface {
	Create(ctx context.Context, user *models.User) error
	FindByID(ctx context.Context, id string) (*models.User, error)
	CheckByEmailOrPhoneNumber(ctx context.Context, email string, phoneNumber string) (bool, error)
	GetOneByAccountNumber(ctx context.Context, accountNumber string) (*models.User, error)
	GetCredentialsByEmailOrPhoneNumber(ctx context.Context, email string, phoneNumber string) (*models.User, error)
}

type healthRepository struct{ db *gorm.DB }

func NewHealthRepository(db *gorm.DB) HealthRepository {
	return &healthRepository{db: db}
}

func (r *healthRepository) Ping(ctx context.Context) error {
	sql, err := r.db.DB()
	if err != nil {
		return err
	}
	return sql.PingContext(ctx)
}

type userRepository struct{ db *gorm.DB }

func NewUserRepository(db *gorm.DB) UserRepository {
	return &userRepository{db: db}
}

func (r *userRepository) Create(ctx context.Context, user *models.User) error {
	return r.db.WithContext(ctx).Create(user).Error
}

func (r *userRepository) FindByID(ctx context.Context, id string) (*models.User, error) {
	var user models.User
	if err := r.db.WithContext(ctx).First(&user, "id = ?", id).Error; err != nil {
		return nil, err
	}
	return &user, nil
}

func (r *userRepository) CheckByEmailOrPhoneNumber(ctx context.Context, email string, phoneNumber string) (bool, error) {
	var exists bool
	if err := r.db.WithContext(ctx).Raw(QueryCheckByEmailOrPhoneNumber, email, email, phoneNumber, phoneNumber).Scan(&exists).Error; err != nil {
		return false, err
	}
	return exists, nil
}

func (r *userRepository) GetOneByAccountNumber(ctx context.Context, accountNumber string) (*models.User, error) {
	var user models.User
	if err := r.db.WithContext(ctx).Raw(QueryGetByAccountNumber, accountNumber).Scan(&user).Error; err != nil {
		return nil, err
	}
	return &user, nil
}

func (r *userRepository) GetCredentialsByEmailOrPhoneNumber(ctx context.Context, email string, phoneNumber string) (*models.User, error) {
	var user models.User
	if err := r.db.WithContext(ctx).Raw(QueryGetCredentialsByEmailOrPhoneNumber, email, email, phoneNumber, phoneNumber).Scan(&user).Error; err != nil {
		return nil, err
	}
	return &user, nil
}
