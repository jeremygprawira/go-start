package database

import (
	"fmt"
	"time"

	"[[.ModuleName]]/internal/config"
	"gorm.io/driver/postgres"
	"gorm.io/gorm"
	"gorm.io/gorm/logger"
)

// ConnectToPostgreSQL creates a GORM-managed PostgreSQL connection pool.
func ConnectToPostgreSQL(cfg *config.Configuration) (*gorm.DB, error) {
	dsn := fmt.Sprintf(
		"host=%s user=%s password=%s dbname=%s port=%d sslmode=%s TimeZone=UTC",
		cfg.PostgreSQL.Host,
		cfg.PostgreSQL.User,
		cfg.PostgreSQL.Password,
		cfg.PostgreSQL.Name,
		cfg.PostgreSQL.Port,
		cfg.PostgreSQL.SSLMode,
	)

	db, err := gorm.Open(postgres.Open(dsn), &gorm.Config{
		Logger: logger.Default.LogMode(logger.Silent),
	})
	if err != nil {
		return nil, fmt.Errorf("failed to connect to postgresql: %w", err)
	}

	sqlDB, err := db.DB()
	if err != nil {
		return nil, err
	}

	connMaxLifetime, _ := time.ParseDuration(cfg.PostgreSQL.ConnMaxLifetime)
	sqlDB.SetMaxIdleConns(cfg.PostgreSQL.MaxIdleConns)
	sqlDB.SetMaxOpenConns(cfg.PostgreSQL.MaxOpenConns)
	sqlDB.SetConnMaxLifetime(connMaxLifetime)

	return db, nil
}

// DisconnectFromPostgreSQL closes the underlying connection pool.
func DisconnectFromPostgreSQL(db *gorm.DB) error {
	sqlDB, err := db.DB()
	if err != nil {
		return err
	}
	return sqlDB.Close()
}
