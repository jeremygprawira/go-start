// transaction_pgsql_repository.go
// Atomic runs a function inside a GORM transaction.
func Atomic(db *gorm.DB, ctx context.Context, fn func(tx *gorm.DB) error) error {
	return db.WithContext(ctx).Transaction(fn)
}

