package http

import (
	"net/http"

	"[[.ModuleName]]/internal/config"
	v1 "[[.ModuleName]]/internal/deliveries/http/api/v1"
	healthcheck "[[.ModuleName]]/internal/deliveries/http/health_check"
	"[[.ModuleName]]/internal/deliveries/http/middleware"
[[- if .UseJWT]]
	"[[.ModuleName]]/internal/pkg/jwtc"
[[- end]]
	"[[.ModuleName]]/internal/service"

	"github.com/labstack/echo/v4"
[[- if .UseSwagger]]
	_ "[[.ModuleName]]/docs"
	echoSwagger "github.com/swaggo/echo-swagger"
[[- end]]
[[- if .UsePrometheus]]
	"github.com/prometheus/client_golang/prometheus/promhttp"
[[- end]]
)

[[- if .UseSwagger]]
// @title [[.ServiceName | title]] API
// @version 1.0
// @description Auto-generated API documentation for [[.ServiceName]].
// @host localhost:8080
// @BasePath /api
// @schemes http https
[[- end]]
[[- if .UseJWT]]
func New(e *echo.Echo, svc *service.Service, cfg *config.Configuration, jwtConfig *jwtc.Configuration) {
[[- else]]
func New(e *echo.Echo, svc *service.Service, cfg *config.Configuration) {
[[- end]]
	mw := middleware.New(e, cfg)
	mw.Default(cfg)

	e.GET("/", func(ctx echo.Context) error {
		return ctx.String(http.StatusOK, "[[.ServiceName]] is running 🚀")
	})
[[- if .UseSwagger]]
	e.GET("/docs", func(ctx echo.Context) error {
		return ctx.File("docs/api-docs.html")
	})
	e.GET("/swagger/*", echoSwagger.WrapHandler)
[[- end]]
[[- if .UsePrometheus]]
	e.GET("/metrics", echo.WrapHandler(promhttp.Handler()))
[[- end]]

	// Health
	health := e.Group("/health")
	healthcheck.New(health, svc)

	// API
	api := e.Group("/api")
	api.Use(middleware.APIKeyMiddleware(cfg))

	// V1
[[- if .UseJWT]]
	v1.New(api, svc, cfg, jwtConfig)
[[- else]]
	v1.New(api, svc, cfg)
[[- end]]
}
