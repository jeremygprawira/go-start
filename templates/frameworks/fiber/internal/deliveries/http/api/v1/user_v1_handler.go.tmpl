package v1

import (
	"[[.ModuleName]]/internal/config"
	"[[.ModuleName]]/internal/models"
	"[[.ModuleName]]/internal/pkg/errorc"
	"[[.ModuleName]]/internal/pkg/validator"
	"[[.ModuleName]]/internal/service"
	"github.com/gofiber/fiber/v2"
[[- if .UseJWT]]
	"[[.ModuleName]]/internal/pkg/jwtc"
[[- end]]
)

type userV1Handler struct {
	svc *service.Service
	cfg *config.Configuration
}

[[- if .UseJWT]]
func NewUserV1(g fiber.Router, svc *service.Service, cfg *config.Configuration, jwtConfig *jwtc.Configuration) {
[[- else]]
func NewUserV1(g fiber.Router, svc *service.Service, cfg *config.Configuration) {
[[- end]]
	h := &userV1Handler{svc: svc, cfg: cfg}
	users := g.Group("/users")
	users.Post("", h.CreateUser)
	users.Get("/:id", h.GetUser)
	users.Put("/:id", h.UpdateUser)
	users.Delete("/:id", h.DeleteUser)
}

func (h *userV1Handler) CreateUser(c *fiber.Ctx) error {
	var req models.CreateUserRequest
	if err := c.BodyParser(&req); err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"message": err.Error()})
	}
	if err := validator.Validate(&req); err != nil {
		return c.Status(fiber.StatusUnprocessableEntity).JSON(fiber.Map{"message": err.Error()})
	}
	result, err := h.svc.User.Create(c.Context(), &req)
	if err != nil {
		if e, ok := err.(*errorc.AppError); ok {
			return c.Status(e.Code).JSON(fiber.Map{"message": e.Message})
		}
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"message": err.Error()})
	}
	return c.Status(fiber.StatusCreated).JSON(result)
}

func (h *userV1Handler) GetUser(c *fiber.Ctx) error {
	result, err := h.svc.User.GetByID(c.Context(), c.Params("id"))
	if err != nil {
		if e, ok := err.(*errorc.AppError); ok {
			return c.Status(e.Code).JSON(fiber.Map{"message": e.Message})
		}
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"message": err.Error()})
	}
	return c.JSON(result)
}

func (h *userV1Handler) UpdateUser(c *fiber.Ctx) error {
	var req models.UpdateUserRequest
	if err := c.BodyParser(&req); err != nil {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{"message": err.Error()})
	}
	result, err := h.svc.User.Update(c.Context(), c.Params("id"), &req)
	if err != nil {
		if e, ok := err.(*errorc.AppError); ok {
			return c.Status(e.Code).JSON(fiber.Map{"message": e.Message})
		}
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"message": err.Error()})
	}
	return c.JSON(result)
}

func (h *userV1Handler) DeleteUser(c *fiber.Ctx) error {
	if err := h.svc.User.Delete(c.Context(), c.Params("id")); err != nil {
		if e, ok := err.(*errorc.AppError); ok {
			return c.Status(e.Code).JSON(fiber.Map{"message": e.Message})
		}
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{"message": err.Error()})
	}
	return c.SendStatus(fiber.StatusNoContent)
}
