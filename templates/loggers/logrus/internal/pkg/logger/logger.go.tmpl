package logger

import (
	"context"
	"os"

	"[[.ModuleName]]/internal/config"

	"github.com/sirupsen/logrus"
)

// LogrusLogger wraps logrus.Logger to implement the Logger interface.
type LogrusLogger struct {
	entry *logrus.Entry
}

// NewLogrusLogger creates a new LogrusLogger instance.
func NewLogrusLogger(entry *logrus.Entry) Logger {
	return &LogrusLogger{entry: entry}
}

// Debug logs a debug message.
func (l *LogrusLogger) Debug(ctx context.Context, msg string, fields ...Field) {
	l.buildEntry(ctx, fields).Debug(msg)
}

// Info logs an info message.
func (l *LogrusLogger) Info(ctx context.Context, msg string, fields ...Field) {
	l.buildEntry(ctx, fields).Info(msg)
}

// Warn logs a warning message.
func (l *LogrusLogger) Warn(ctx context.Context, msg string, fields ...Field) {
	l.buildEntry(ctx, fields).Warn(msg)
}

// Error logs an error message.
func (l *LogrusLogger) Error(ctx context.Context, msg string, fields ...Field) {
	l.buildEntry(ctx, fields).Error(msg)
}

// Fatal logs a fatal message and exits.
func (l *LogrusLogger) Fatal(ctx context.Context, msg string, fields ...Field) {
	l.buildEntry(ctx, fields).Fatal(msg)
}

// With returns a logger with preset fields.
func (l *LogrusLogger) With(fields ...Field) Logger {
	return &LogrusLogger{entry: l.entry.WithFields(convertLogrusFields(fields))}
}

// WithContext returns a logger with context values extracted and preset.
func (l *LogrusLogger) WithContext(ctx context.Context) Logger {
	f := logrus.Fields{}
	if requestID := GetRequestID(ctx); requestID != "" {
		f["request_id"] = requestID
	}
	if userID := GetUserID(ctx); userID != "" {
		f["user_id"] = userID
	}
	if traceID := GetTraceID(ctx); traceID != "" {
		f["trace_id"] = traceID
	}
	return &LogrusLogger{entry: l.entry.WithFields(f)}
}

func (l *LogrusLogger) buildEntry(ctx context.Context, fields []Field) *logrus.Entry {
	f := convertLogrusFields(fields)
	if ctx != nil {
		if requestID := GetRequestID(ctx); requestID != "" {
			f["request_id"] = requestID
		}
		if userID := GetUserID(ctx); userID != "" {
			f["user_id"] = userID
		}
		if traceID := GetTraceID(ctx); traceID != "" {
			f["trace_id"] = traceID
		}
	}
	return l.entry.WithFields(f)
}

func convertLogrusFields(fields []Field) logrus.Fields {
	lf := make(logrus.Fields, len(fields))
	for _, f := range fields {
		if f.Type == FieldTypeError {
			if err, ok := f.Value.(error); ok {
				lf[f.Key] = err.Error()
				continue
			}
		}
		lf[f.Key] = f.Value
	}
	return lf
}

// Log is the raw logrus.Logger instance.
var Log *logrus.Logger

// Initialize configures and initializes the global logger based on environment.
func Initialize(configuration *config.Configuration) {
	Log = logrus.New()
	Log.SetOutput(os.Stdout)
	Log.SetReportCaller(true)

	isProduction := configuration.Application.Environment == "prod" ||
		configuration.Application.Environment == "production"

	if isProduction {
		Log.SetFormatter(&logrus.JSONFormatter{})
		Log.SetLevel(logrus.InfoLevel)
	} else {
		Log.SetFormatter(&logrus.TextFormatter{
			FullTimestamp: true,
			ForceColors:   true,
		})
		Log.SetLevel(logrus.DebugLevel)
	}

	Instance = NewLogrusLogger(logrus.NewEntry(Log))

	if isProduction {
		Log.WithFields(logrus.Fields{
			"environment": configuration.Application.Environment,
			"encoding":    "json",
			"level":       "info",
		}).Info("Logger initialized in production mode")
	} else {
		Log.WithFields(logrus.Fields{
			"environment": configuration.Application.Environment,
			"encoding":    "console",
			"level":       "debug",
		}).Info("Logger initialized in development mode")
	}
}
