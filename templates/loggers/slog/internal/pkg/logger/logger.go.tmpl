package logger

import (
	"context"
	"log/slog"
	"os"

	"[[.ModuleName]]/internal/config"
)

// SlogLogger wraps slog.Logger to implement the Logger interface.
type SlogLogger struct {
	logger *slog.Logger
}

// NewSlogLogger creates a new SlogLogger instance.
func NewSlogLogger(slogLog *slog.Logger) Logger {
	return &SlogLogger{logger: slogLog}
}

// Debug logs a debug message.
func (s *SlogLogger) Debug(ctx context.Context, msg string, fields ...Field) {
	s.logger.DebugContext(ctx, msg, s.buildArgs(ctx, fields)...)
}

// Info logs an info message.
func (s *SlogLogger) Info(ctx context.Context, msg string, fields ...Field) {
	s.logger.InfoContext(ctx, msg, s.buildArgs(ctx, fields)...)
}

// Warn logs a warning message.
func (s *SlogLogger) Warn(ctx context.Context, msg string, fields ...Field) {
	s.logger.WarnContext(ctx, msg, s.buildArgs(ctx, fields)...)
}

// Error logs an error message.
func (s *SlogLogger) Error(ctx context.Context, msg string, fields ...Field) {
	s.logger.ErrorContext(ctx, msg, s.buildArgs(ctx, fields)...)
}

// Fatal logs a fatal message and exits.
func (s *SlogLogger) Fatal(ctx context.Context, msg string, fields ...Field) {
	// slog doesn't have Fatal out of the box so we Error and exit
	s.logger.ErrorContext(ctx, msg, s.buildArgs(ctx, fields)...)
	os.Exit(1)
}

// With returns a logger with preset fields.
func (s *SlogLogger) With(fields ...Field) Logger {
	return &SlogLogger{logger: s.logger.With(convertSlogFields(fields)...)}
}

// WithContext returns a logger with context values extracted and preset.
func (s *SlogLogger) WithContext(ctx context.Context) Logger {
	args := extractContextArgs(ctx)
	if len(args) == 0 {
		return s
	}
	return &SlogLogger{logger: s.logger.With(args...)}
}

func (s *SlogLogger) buildArgs(ctx context.Context, fields []Field) []any {
	ctxArgs := extractContextArgs(ctx)
	userArgs := convertSlogFields(fields)

	args := make([]any, 0, len(ctxArgs)+len(userArgs))
	args = append(args, ctxArgs...)
	args = append(args, userArgs...)
	return args
}

func extractContextArgs(ctx context.Context) []any {
	if ctx == nil {
		return nil
	}
	args := make([]any, 0, 6)
	if requestID := GetRequestID(ctx); requestID != "" {
		args = append(args, slog.String("request_id", requestID))
	}
	if userID := GetUserID(ctx); userID != "" {
		args = append(args, slog.String("user_id", userID))
	}
	if traceID := GetTraceID(ctx); traceID != "" {
		args = append(args, slog.String("trace_id", traceID))
	}
	return args
}

func convertSlogFields(fields []Field) []any {
	args := make([]any, 0, len(fields))
	for _, f := range fields {
		switch f.Type {
		case FieldTypeString:
			args = append(args, slog.String(f.Key, f.Value.(string)))
		case FieldTypeInt:
			args = append(args, slog.Int(f.Key, f.Value.(int)))
		case FieldTypeInt64:
			args = append(args, slog.Int64(f.Key, f.Value.(int64)))
		case FieldTypeBool:
			args = append(args, slog.Bool(f.Key, f.Value.(bool)))
		case FieldTypeError:
			args = append(args, slog.Any(f.Key, f.Value))
		default:
			args = append(args, slog.Any(f.Key, f.Value))
		}
	}
	return args
}

// Log is the raw slog.Logger instance.
var Log *slog.Logger

// Initialize configures and initializes the global logger based on environment.
func Initialize(configuration *config.Configuration) {
	isProduction := configuration.Application.Environment == "prod" ||
		configuration.Application.Environment == "production"

	var handler slog.Handler
	if isProduction {
		opts := &slog.HandlerOptions{
			Level:     slog.LevelInfo,
			AddSource: true,
		}
		handler = slog.NewJSONHandler(os.Stdout, opts)
	} else {
		opts := &slog.HandlerOptions{
			Level:     slog.LevelDebug,
			AddSource: true,
		}
		handler = slog.NewTextHandler(os.Stdout, opts)
	}

	Log = slog.New(handler)
	slog.SetDefault(Log)
	Instance = NewSlogLogger(Log)

	if isProduction {
		Log.Info("Logger initialized in production mode",
			slog.String("environment", configuration.Application.Environment),
			slog.String("encoding", "json"),
			slog.String("level", "info"),
		)
	} else {
		Log.Info("Logger initialized in development mode",
			slog.String("environment", configuration.Application.Environment),
			slog.String("encoding", "console"),
			slog.String("level", "debug"),
		)
	}
}
